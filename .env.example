# ===== Payments (demo | stripe | moyasar) =====
PAYMENT_PROVIDER=demo
# في الإنتاج: لا تستخدم demo إلا للتجربة مع ALLOW_DEMO_PAYMENTS=true
ALLOW_DEMO_PAYMENTS=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MOYASAR_SECRET_KEY=
MOYASAR_PUBLISHABLE_KEY=

# ===== Backend =====
PORT=3001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/businessos
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# ===== OpenAI =====
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ===== Google Gemini (اختياري — يُدار أيضاً من لوحة الأدمن) =====
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ===== WhatsApp Business Cloud API =====
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=

# ===== Meta Embedded Signup =====
META_APP_ID=
META_APP_SECRET=
META_EMBEDDED_SIGNUP_CONFIG_ID=
META_GRAPH_VERSION=v21.0

# ===== Green API (بديل Meta) =====
GREEN_API_URL=https://7107.api.greenapi.com
GREEN_API_MEDIA_URL=https://7107.api.greenapi.com
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN_INSTANCE=
GREEN_API_PHONE=

# ===== Frontend =====
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_META_APP_ID=
